{
  "name": "restaurant-pos",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:desktop": "npm run start --workspace=apps/desktop",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:desktop\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "prisma": "^7.8.0"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "electron-is-dev": "^3.0.1"
  }
}
