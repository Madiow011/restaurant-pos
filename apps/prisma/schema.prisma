// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==============================
// MENU MODELS
// ==============================

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  icon      String?   // emoji หรือ icon name เช่น "🍕"
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@map("categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  imageUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  Int
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]

  @@map("products")
}

// ==============================
// TABLE MODELS
// ==============================

model Table {
  id         Int         @id @default(autoincrement())
  number     Int         @unique  // เลขโต๊ะ เช่น 1, 2, 3
  name       String?              // ชื่อโต๊ะ เช่น "โต๊ะ VIP"
  capacity   Int         @default(4)
  status     TableStatus @default(AVAILABLE)
  posX       Int?        // ตำแหน่ง X สำหรับ floor map (อนาคต)
  posY       Int?        // ตำแหน่ง Y สำหรับ floor map (อนาคต)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  orders     Order[]

  @@map("tables")
}

enum TableStatus {
  AVAILABLE  // ว่าง
  OCCUPIED   // มีลูกค้า
  RESERVED   // จอง
  CLEANING   // กำลังทำความสะอาด
}

// ==============================
// ORDER MODELS
// ==============================

model Order {
  id          Int         @id @default(autoincrement())
  orderNumber String      @unique  // เลขออเดอร์ เช่น "ORD-20240101-001"
  status      OrderStatus @default(OPEN)

  // ราคา
  subtotal    Float       @default(0)
  vatRate     Float       @default(0.07)  // VAT 7%
  vatAmount   Float       @default(0)
  totalAmount Float       @default(0)

  // การชำระเงิน
  paymentMethod PaymentMethod?
  paidAt        DateTime?
  note          String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tableId     Int
  table       Table       @relation(fields: [tableId], references: [id])
  orderItems  OrderItem[]

  @@map("orders")
}

enum OrderStatus {
  OPEN       // กำลังสั่ง
  CONFIRMED  // ยืนยันแล้ว ส่งครัวแล้ว
  READY      // อาหารพร้อม
  PAID       // ชำระเงินแล้ว
  CANCELLED  // ยกเลิก
}

enum PaymentMethod {
  CASH        // เงินสด
  CREDIT_CARD // บัตรเครดิต
  QR_CODE     // QR Code / พร้อมเพย์
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(1)
  unitPrice Float    // ราคา ณ เวลาที่สั่ง (snapshot)
  subtotal  Float    // quantity * unitPrice
  note      String?  // หมายเหตุพิเศษ เช่น "ไม่เผ็ด"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}